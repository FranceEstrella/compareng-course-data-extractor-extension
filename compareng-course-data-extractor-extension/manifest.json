{
    "manifest_version": 3,
    "name": "ComParEng Courses Data Extractor",
    "version": "1.1.0",
    "description": "Extracts course data from the student portal to the ComParEng's tools.",

    "host_permissions": [
      "http://localhost:3000/*",
      "https://compareng-tools.vercel.app/*",
      "https://compareng-coursetracker.vercel.app/*",
      "https://solar.feutech.edu.ph/*",
      "https://*.feutech.edu.ph/*"
    ],

    "permissions": [
      "storage",
      "tabs"
    ],

    "content_scripts": [
      {
        "matches": [
          "https://solar.feutech.edu.ph/*",
          "https://*.feutech.edu.ph/*"
        ],
        "js": [
          "oses-success-verifier.js",
          "oses-auth-state.js",
          "oses-iframe-monitor.js",
          "content.js"
        ],
        "all_frames": true,
        "run_at": "document_idle"
      }
    ],
    "background": {
      "service_worker": "background.js"
    },
    "externally_connectable": {
      "matches": [
        "https://compareng-tools.vercel.app/*",
        "https://compareng-coursetracker.vercel.app/*",
        "https://*.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
      }
    },
    "icons": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  }